# Google Gemini API Key
# 获取: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# 视频分析模型（默认 gemini-2.5-flash，与 AI Studio 里非 0/0 的模型一致）
# 上传视频请压至约 3.5MB 以内（Vercel 请求体上限约 4.5MB）
# 勿用 gemini-2.0-flash / 2.0-flash-lite / 2.5-flash-lite（许多免费 Key 为 0/0）
GEMINI_MODEL=gemini-2.5-flash

# Vercel Blob（部署到 Vercel 时必填，用于异步分析规避 10 秒超时）
# 在 Vercel 控制台 → Storage → Blob → 创建并连接项目后自动注入
# 本地开发可在 Vercel Dashboard 复制 BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
